          "gap": 80,
          "padding": 80,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "d33Cr",
              "name": "leadImg",
              "metadata": {
                "type": "unsplash",
                "username": "andriyko",
                "link": "https://unsplash.com/@andriyko",
                "author": "Andriyko Podilnyk"
              },
              "width": 460,
              "height": 380,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1580684092171-6f6bfd75806d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3Nzk0Mzk1MjV8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"
              },
              "cornerRadius": 16
            },
            {
              "type": "frame",
              "id": "bT3w1",
              "name": "leadText",
              "width": 640,
              "layout": "vertical",
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "lvUT4",
                  "fill": "#C4A77D",
                  "content": "LEADERSHIP",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "600",
                  "letterSpacing": 4
                },
                {
                  "type": "text",
                  "id": "b7RNjL",
                  "fill": "#FFFFFF",
                  "content": "\"We build foundations for Mongolia's future.\"",
                  "fontFamily": "Inter",
                  "fontSize": 32,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "fSHjP",
                  "fill": "#A0A0A0",
                  "content": "Our leadership philosophy is rooted in long-term thinking and sustainable growth. We believe every structure we build should serve generations to come, creating lasting value for communities and the nation.",
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
