                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uGTnz",
                  "fill": "#A0A0A0",
                  "content": "Our Mission: To build with integrity, innovate with purpose, and create lasting value for our clients, employees, and the nation of Mongolia.",
