                  "fill": "#D63031",
                  "content": "БИДНИЙ ТУХАЙ",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "normal",
                  "letterSpacing": 3
                },
                {
                  "type": "text",
                  "id": "tlTsU",
                  "name": "aboutTitle",
                  "fill": "#1A3C34",
                  "textGrowth": "fixed-width",
                  "width": 500,
                  "content": "Tech Invent ХХК",
                  "fontFamily": "Inter",
                  "fontSize": 40,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "qulQx",
                  "name": "aboutDesc",
                  "fill": "#5A6B66",
                  "textGrowth": "fixed-width",
                  "width": 500,
                  "content": "Tech Invent ХХК нь 2015 онд байгуулагдсан бөгөөд Европын шилдэг брэндүүдийн албан ёсны дистрибьютерээр ажиллаж байна. Бид Zehnder, BWT зэрэг дэлхийд танигдсан брэндүүдийн Монгол дахь түнш юм.\n\nАлсын хараа: Эрүүл агаар, тав тухтай орчин бүхий Монголын ирээдүйг бүтээх\nЗорилго: Европын шилдэг технологийг Монголд нэвтрүүлж, хэрэглэгчдэд хамгийн сайн шийдлийг өгөх\nЗорилт: 2025 он гэхэд Монголын агааржуулалтын зах зээлийн тэргүүлэгч болох",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "wNIYc",
